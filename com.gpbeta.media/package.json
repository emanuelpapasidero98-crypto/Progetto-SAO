{
    "name": "com.gpbeta.media",
    "version": "1.3.3",
    
    "title": {
        "en": "Media Support Extension",
        "zh": "多媒体支持扩展",
        "zh_TW": "多媒體支持擴展",
        "ja": "マルチメディア拡張機能"
    },

    "description": {
        "en": "Provides image and video widgets, data source and actions for system media player, CAD compatible player, QQ Music, NetEase Music, etc.",
        "zh": "提供图片和视频挂件，以及对系统多媒体控制、CAD 兼容播放器、QQ 音乐和网易云音乐等数据源和动作支持。",
        "zh_TW": "提供圖片和視頻掛件，以及對系統多媒體控製、CAD 兼容播放器、QQ 音樂和網易雲音樂等數據源和動作支持。",
        "ja": "画像とビデオのウィジェット、及びシステムメディアプレーヤー、CAD コンパチプレーヤー、QQ Music、NetEase Music などのデータソースとアクションを提供します。"
    },

    "homepage": "http://sao.gpbeta.com",
    "bugs": { "email": "studiocghibli@gmail.com", "url": "https://nvg.dev/core/sao-utils/issues" },
    "author": { "name": "Joshua GPBeta", "email": "studiocghibli@gmail.com", "url": "http://www.gpbeta.com" },
    "contributors": [
        { "name": "RangerCD", "email": "compact-disk@live.com", "url": "http://www.rangercd.com" }
    ],

    "engines": {
        "qt.quick": ">=2.12",
        "nvg.api": "~1"
    },

