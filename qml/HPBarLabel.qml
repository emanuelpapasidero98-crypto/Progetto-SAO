import QtQuick 2.12

Text {
    color: "#CCFFFFFF"
    maximumLineCount: 1
    verticalAlignment: Text.AlignVCenter
    horizontalAlignment: Text.AlignHCenter
    wrapMode: Text.WrapAnywhere

    style: Text.Outline
    styleColor: "#22FFFFFF"

    font.family: "SAO UI, Source Han Sans"
    font.pixelSize: 14
}
